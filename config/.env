# Non-secret config only.
# Secrets must live in `.env_credentials` (ignored by git).
#
# Example (put in `.env_credentials`, NOT here):
#   GOOGLE_API_KEY=...
#   GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service_account.json

GOOGLE_CLOUD_PROJECT=naeda-genesis
GOOGLE_CLOUD_LOCATION=us-central1
AGI_LIGHT_MODE=sun
AGI_LATITUDE=37.5665
AGI_LONGITUDE=126.9780
